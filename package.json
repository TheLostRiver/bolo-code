{
  "name": "bolo-code",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-platform graphical AI coding agent (Electron + headless core)",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bolo": "./packages/cli/bin/bolo.js"
  },
  "scripts": {
    "smoke": "tsx scripts/smoke-turn.ts",
    "test:compact": "tsx scripts/test-compact.ts",
    "dev": "tsx scripts/smoke-turn.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:provider": "tsx scripts/test-provider-unit.ts",
    "smoke:live": "tsx scripts/smoke-live.ts",
    "test:config": "tsx scripts/test-config.ts",
    "bolo:init": "tsx scripts/bolo-init.ts",
    "test:skills": "tsx scripts/test-skill-catalog.ts",
    "test:system-prompt": "tsx scripts/test-system-prompt.ts",
    "test:prompt-cache": "tsx scripts/test-prompt-cache.ts",
    "test:rules": "tsx scripts/test-rules.ts",
    "test:auto-compact": "tsx scripts/test-auto-compact.ts",
    "test:session": "tsx scripts/test-session-persist.ts",
    "test:cli": "tsx scripts/test-cli-resume.ts",
    "test:session-list": "tsx scripts/test-session-list.ts",
    "test:slash": "tsx scripts/test-slash.ts",
    "test:mcp": "tsx scripts/test-mcp-stdio.ts",
    "test": "tsx scripts/test-compact.ts && tsx scripts/test-permissions.ts && tsx scripts/test-provider-unit.ts && tsx scripts/test-config.ts && tsx scripts/test-skill-catalog.ts && tsx scripts/test-system-prompt.ts && tsx scripts/test-prompt-cache.ts && tsx scripts/test-rules.ts && tsx scripts/test-auto-compact.ts && tsx scripts/test-session-persist.ts && tsx scripts/test-cli-resume.ts && tsx scripts/test-session-list.ts && tsx scripts/test-slash.ts && tsx scripts/test-mcp-stdio.ts && tsx scripts/smoke-turn.ts",
    "test:ptl": "tsx scripts/test-ptl-retry.ts",
    "test:model-retry": "tsx scripts/test-model-retry.ts",
    "test:permissions": "tsx scripts/test-permissions.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheLostRiver/bolo-code.git"
  },
  "license": "MIT"
}