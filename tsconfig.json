{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@bolo/shared": ["packages/shared/src/index.ts"],
      "@bolo/core": ["packages/core/src/index.ts"],
      "@bolo/hooks": ["packages/hooks/src/index.ts"],
      "@bolo/tools": ["packages/tools/src/index.ts"],
      "@bolo/skills": ["packages/skills/src/index.ts"],
      "@bolo/mcp": ["packages/mcp/src/index.ts"],
      "@bolo/plugins": ["packages/plugins/src/index.ts"],
      "@bolo/providers": ["packages/providers/src/index.ts"],
      "@bolo/compact": ["packages/compact/src/index.ts"],
      "@bolo/permissions": ["packages/permissions/src/index.ts"],
      "@bolo/config": ["packages/config/src/index.ts"],
      "@bolo/cli": ["packages/cli/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "apps/*/src/**/*.ts",
    "scripts/**/*.ts"
  ]
}